import { Button, LineEdit, ListView, VerticalBox, HorizontalBox, StandardButton } from "std-widgets.slint";

export component MainWindow inherits Window {
    title: "cybercuris";
    min-width: 420px;
    min-height: 480px;

    in property <[string]> password-names;
    in property <string> status;
    in-out property <bool> locked: true;
    in property <bool> needs-init: false;
    in-out property <bool> show-add-password: false;
    in-out property <bool> show-edit-password: false;
    in-out property <string> edit-original-name;
    in-out property <string> filter-text;

    callback store-password(name: string, password: string);
    callback edit-password(old-name: string, new-name: string, new-password: string);
    callback copy-password(name: string);
    callback remove-password(name: string);
    callback refresh();
    callback hide-window();
    callback lock();
    callback exit();
    callback unlock-password(password: string);
    callback set-init-password(p1: string, p2: string);
    callback filter-changed(string);

    FocusScope {
        key-pressed(event) => {
            if event.text == "\u{001b}" {
                if root.filter-text == "" {
                    root.hide-window();
                } else {
                    root.filter-text = "";
                    root.filter-changed("");
                }
                return accept;
            }
            reject
        }

        if root.locked : VerticalBox {
            padding: 12px;
            spacing: 8px;
            alignment: center;

            if root.needs-init : VerticalBox {
                Text {
                    text: "Set a password to protect your main key.\nThis password will be required each time\nyou unlock your password store.";
                    font-size: 14px;
                }

                pass1 := LineEdit {
                    placeholder-text: "New password";
                    input-type: password;
                    init => { pass1.focus(); }
                    accepted => { pass2.focus(); }
                }

                pass2 := LineEdit {
                    placeholder-text: "Confirm password";
                    input-type: password;
                    accepted => { root.set-init-password(pass1.text, pass2.text); }
                }

                Button {
                    text: "Set Password";
                    primary: true;
                    clicked => { root.set-init-password(pass1.text, pass2.text); }
                }

                Text {
                    text: root.status;
                    color: #d04040;
                    wrap: word-wrap;
                    font-size: 12px;
                }
            }

            if !root.needs-init : VerticalBox {
                Text {
                    text: "Enter main key password:";
                    font-size: 14px;
                }

                unlock-pass := LineEdit {
                    placeholder-text: "Password";
                    input-type: password;
                    init => { unlock-pass.focus(); }
                    accepted => { root.unlock-password(unlock-pass.text); }
                }

                Text {
                    text: root.status;
                    color: #d04040;
                    wrap: word-wrap;
                    font-size: 12px;
                }
            }
        }

        if !root.locked : VerticalBox {
            padding: 8px;
            spacing: 4px;

            Text {
                text: "Stored Passwords";
                font-size: 16px;
                font-weight: 700;
            }

            search := LineEdit {
                placeholder-text: "Search passwords...";
                text <=> root.filter-text;
                init => { search.focus(); }
                edited => { root.filter-changed(root.filter-text); }
                accepted => {
                    if root.password-names.length > 0 {
                        root.copy-password(root.password-names[0]);
                    }
                }
            }

            ListView {
                vertical-stretch: 1;
                for name[idx] in root.password-names: HorizontalBox {
                    padding: 2px;
                    if idx == 0 : Text {
                        text: name;
                        horizontal-stretch: 1;
                        overflow: elide;
                        color: #1564c0;
                        font-size: 1.5rem;
                    }
                    if idx != 0 : Text {
                        text: name;
                        horizontal-stretch: 1;
                        overflow: elide;
                        font-size: 1.5rem;
                    }
                    Button {
                        text: "Copy";
                        clicked => {
                            root.copy-password(name);
                        }
                    }
                    Button {
                        text: "Edit";
                        clicked => {
                            root.edit-original-name = name;
                            root.show-add-password = false;
                            root.show-edit-password = true;
                        }
                    }
                    Button {
                        text: "Remove";
                        clicked => {
                            root.remove-password(name);
                        }
                    }
                }
            }

            if root.show-add-password : VerticalBox {
                spacing: 4px;

                name-edit := LineEdit {
                    placeholder-text: "Name";
                    init => { name-edit.focus(); }
                }

                password-edit := LineEdit {
                    placeholder-text: "Password";
                    input-type: password;
                    accepted => {
                        root.store-password(name-edit.text, password-edit.text);
                        password-edit.text = "";
                        root.show-add-password = false;
                        root.filter-text = "";
                        search.focus();
                    }
                }

                HorizontalBox {
                    alignment: end;
                    spacing: 4px;

                    Button {
                        text: "Cancel";
                        clicked => {
                            root.show-add-password = false;
                            root.filter-text = "";
                            search.focus();
                        }
                    }
                    Button {
                        text: "Store";
                        primary: true;
                        clicked => {
                            root.store-password(name-edit.text, password-edit.text);
                            password-edit.text = "";
                            root.show-add-password = false;
                            root.filter-text = "";
                            search.focus();
                        }
                    }
                }
            }

            if root.show-edit-password : VerticalBox {
                spacing: 4px;

                edit-name-edit := LineEdit {
                    placeholder-text: "Name";
                    init => {
                        edit-name-edit.text = root.edit-original-name;
                        edit-name-edit.focus();
                    }
                }

                edit-password-edit := LineEdit {
                    placeholder-text: "Password (leave empty to keep current)";
                    input-type: password;
                    accepted => {
                        root.edit-password(root.edit-original-name, edit-name-edit.text, edit-password-edit.text);
                        edit-password-edit.text = "";
                        root.show-edit-password = false;
                        root.filter-text = "";
                        search.focus();
                    }
                }

                HorizontalBox {
                    alignment: end;
                    spacing: 4px;

                    Button {
                        text: "Cancel";
                        clicked => {
                            root.show-edit-password = false;
                            root.filter-text = "";
                            search.focus();
                        }
                    }
                    Button {
                        text: "Save";
                        primary: true;
                        clicked => {
                            root.edit-password(root.edit-original-name, edit-name-edit.text, edit-password-edit.text);
                            edit-password-edit.text = "";
                            root.show-edit-password = false;
                            root.filter-text = "";
                            search.focus();
                        }
                    }
                }
            }

            Text {
                text: root.status;
                wrap: word-wrap;
                color: root.status == "" ? transparent : #a0a0a0;
            }

            HorizontalBox {
                alignment: start;
                spacing: 4px;

                Button {
                    text: "Add";
                    clicked => {
                        root.show-edit-password = false;
                        root.show-add-password = true;
                    }
                }
                Button {
                    text: "Lock";
                    clicked => { root.lock(); }
                }
                Button {
                    text: "Hide";
                    clicked => { root.hide-window(); }
                }
                Button {
                    text: "Exit";
                    clicked => { root.exit(); }
                }
            }
        }
    }
}

export component UnlockDialog inherits Dialog {
    title: "Unlock Cybercuris";

    in-out property <string> password-text;
    callback accepted;

    forward-focus: password-input;

    VerticalBox {
        padding: 12px;
        spacing: 8px;

        Text {
            text: "Enter main key password:";
            font-size: 14px;
        }

        password-input := LineEdit {
            placeholder-text: "Password";
            input-type: password;
            text <=> root.password-text;
            accepted => { root.accepted(); }
        }
    }

    StandardButton { kind: ok; }
    StandardButton { kind: cancel; }
}

export component SetPasswordDialog inherits Dialog {
    title: "Initialize Cybercuris";

    in-out property <string> password1;
    in-out property <string> password2;
    callback accepted;

    forward-focus: pass1;

    VerticalBox {
        padding: 12px;
        spacing: 8px;

        Text {
            text: "Set a password to protect your main key.\nThis password will be required each time\nyou unlock your password store.";
            font-size: 14px;
        }

        pass1 := LineEdit {
            placeholder-text: "New password";
            input-type: password;
            text <=> root.password1;
            accepted => { pass2.focus(); }
        }

        pass2 := LineEdit {
            placeholder-text: "Confirm password";
            input-type: password;
            text <=> root.password2;
            accepted => { root.accepted(); }
        }
    }

    StandardButton { kind: ok; }
    StandardButton { kind: cancel; }
}

export component CybercurisTray inherits SystemTrayIcon {
    icon: @image-url("../../icons/cybercuris.png");
    tooltip: "cybercuris";

    callback show-window;
    callback quit;

    clicked => { root.show-window(); }

    Menu {
        MenuItem {
            title: "Show cybercuris";
            activated => { root.show-window(); }
        }
        MenuSeparator {}
        MenuItem {
            title: "Quit";
            activated => { root.quit(); }
        }
    }
}
